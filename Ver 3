  "monster_manual_ii_bookworm": {
    "name": "BOOKWORM",
    "source": "Monster Manual II",
    "sheet": {
      "frequency": "Rare",
      "no_appearing": "1-2 (10-40)",
      "armorclass": "2",
      "movement": "12\" (3\")",
      "monsterHD": "1/4 (2 hit points)",
