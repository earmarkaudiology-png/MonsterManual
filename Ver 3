      "special_defenses": "See below",
      "magic_resistance": "1% per year of age",
      "intelligence": "Low",
      "alignment": "Neutral (evil)",
      "size": "L (20'+ tall)",
      "psionic_ability": "Nil",
      "attack_defense_modes": "Nil/nil",
