    function findMatchesByBook(query, bookKey) {
        var norm = normalizeName(query);
        var monsters = getMonstersForBook(bookKey);
        var exact = [];
        var partial = [];
        var i, m, nm;
        for (i = 0; i < monsters.length; i++) {
            m = monsters[i];
            nm = normalizeName(m.name);
            if (nm === norm) exact.push(m);
            else if (nm.indexOf(norm) !== -1) partial.push(m);
        }
        return exact.concat(partial).slice(0, 60);
    }

