      "no_appearing": "1",
      "armorclass": "3",
      "movement": "12\"",
      "monsterHD": "9",
      "percent_in_lair": "10%",
      "treasure_type": "See below",
      "no_of_attacks": "1",
      "damage_attack": "3-12",
      "special_attacks": "Death vibration",
      "special_defenses": "Nil/camouflage",
      "magic_resistance": "Standard",
