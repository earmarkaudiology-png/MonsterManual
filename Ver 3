  "monster_manual_ii_hydrodaemon_lesser_daemon": {
    "name": "HYDRODAEMON, LESSER DAEMON",
    "source": "Monster Manual II",
    "sheet": {
      "frequency": "Uncommon",
      "no_appearing": "2-8",
      "armorclass": "2",
      "movement": "6\"/6\" (MC:D)//24\"",
      "monsterHD": "9+36",
      "percent_in_lair": "5% (90% if near Styx)",
      "treasure_type": "I, Y",
      "no_of_attacks": "3 or 5",
      "damage_attack": "1-4/1-4/1-8/1-8/1-10",
      "special_attacks": "Energy drain",
      "special_defenses": "See below",
      "magic_resistance": "70% to 1st-level spells",
      "intelligence": "Low",
      "alignment": "Neutral evil",
      "size": "L (10' tall)",
      "psionic_ability": "Nil",
      "attack_defense_modes": "Nil/nil",
      "level_xp_value": "VIII/3450 + 14/hp",
      "monsterhd": "9",
