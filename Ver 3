      "armorclass": "1",
      "movement": "12\"/18\"",
      "monsterHD": "8+3",
      "percent_in_lair": "25%",
      "treasure_type": "F",
      "no_of_attacks": "1",
      "damage_attack": "5-10",
      "special_attacks": "Energy drain",
      "special_defenses": "+1 or better weapon to hit",
      "magic_resistance": "See below",
      "intelligence": "Exceptional",
      "alignment": "Chaotic evil",
      "size": "M",
