    var ATTR_AC_OVERRIDE = 'armorclass_override';
    var ATTR_MOVE = 'movement';
    var ATTR_MOVE_OVERRIDE = 'movement_override';
    var ATTR_MORALE_BASE = 'morale_base';
    var ATTR_MORALE = 'morale';
    var ATTR_MONSTER_MORALE = 'monstermorale';

    function hasText(value) {
        return value !== undefined && value !== null && String(value).trim() !== '';
    }

    function toInt(value, fallback) {
        var n = parseInt(value, 10);
        return isNaN(n) ? fallback : n;
    }

    function clamp(value, min, max) {
        return Math.max(min, Math.min(max, value));
    }

    function formatBonus(n) {
        if (!n) return '';
        return (n > 0 ? '+' : '') + n;
    }

    function setAttrWithMax(cid, name, currentValue, maxValue) {
        var a = getOrCreateAttr(cid, name);
        a.set({ current: currentValue || '', max: maxValue || '' });
        return a;
    }

    function setMoraleAttributes(characterId, value) {
        setAttrWithMax(characterId, ATTR_MORALE_BASE, value, value);
        setAttrWithMax(characterId, ATTR_MORALE, value, value);
        setAttrWithMax(characterId, ATTR_MONSTER_MORALE, value, value);
    }

    function parseMonsterHD(hdRaw, bonusRaw) {
        var hdText = String(hdRaw || '').replace(/\s+/g, '').toLowerCase();
        var sheetBonus = toInt(bonusRaw, 0);
        var m, dice, inlineBonus, totalBonus;

        if (!hdText) return null;
        hdText = hdText.replace(/^hd/, '');

        if (/^\d+$/.test(hdText)) {
            dice = parseInt(hdText, 10);
            return {
                type: 'normal',
                dice: dice,
                bonus: sheetBonus,
                label: dice + 'd8' + formatBonus(sheetBonus),
                fullHD: dice
            };
        }

        m = hdText.match(/^(\d+)([+-]\d+)$/);
        if (m) {
            dice = parseInt(m[1], 10);
            inlineBonus = parseInt(m[2], 10);
            totalBonus = inlineBonus + sheetBonus;
            return {
                type: 'normal',
                dice: dice,
                bonus: totalBonus,
                label: dice + 'd8' + formatBonus(totalBonus),
                fullHD: dice
            };
        }

        if (hdText === '1/2') {
            return {
                type: 'fraction',
                die: 4,
                bonus: sheetBonus,
                label: '1d4' + formatBonus(sheetBonus),
                fullHD: 0
            };
        }

        if (hdText === '1/4') {
            return {
                type: 'fraction',
                die: 2,
                bonus: sheetBonus,
                label: '1d2' + formatBonus(sheetBonus),
                fullHD: 0
            };
        }

        return null;
    }

    function rollParsedHD(parsed) {
        var total = parsed.bonus || 0;
        var rolls = [];
        var i, r;

        if (parsed.type === 'normal') {
            for (i = 0; i < parsed.dice; i++) {
                r = randomInteger(8);
                rolls.push(r);
                total += r;
            }
        } else if (parsed.type === 'fraction') {
            r = randomInteger(parsed.die);
            rolls.push(r);
            total += r;
        } else {
            return null;
        }

        if (total < 1) total = 1;
        return { total: total, rolls: rolls };
    }

    function calculateBaseMorale(parsedHD) {
        var morale = 50;
        if (parsedHD.fullHD > 1) morale += (parsedHD.fullHD - 1) * 5;
        return clamp(morale, 1, 100);
    }

    function chooseACValue(charId, token) {
        var overrideValue = getAttrByName(charId, ATTR_AC_OVERRIDE);
        var baseValue = getAttrByName(charId, ATTR_AC);
        var tokenValue = token.get('bar2_value');
        if (hasText(overrideValue)) return String(overrideValue);
        if (hasText(tokenValue)) return String(tokenValue);
        if (hasText(baseValue)) return String(baseValue);
        return '';
    }

    function chooseMoveValue(charId, token) {
        var overrideValue = getAttrByName(charId, ATTR_MOVE_OVERRIDE);
        var baseValue = getAttrByName(charId, ATTR_MOVE);
        var tokenValue = token.get('bar3_value');
        if (hasText(overrideValue)) return String(overrideValue);
        if (hasText(tokenValue)) return String(tokenValue);
        if (hasText(baseValue)) return String(baseValue);
        return '';
    }


    function normalizeDashText(value) {
        return String(value || '').replace(/[–—−]/g, '-').trim();
    }

    function toSheetSizeLetter(value) {
        var t = String(value || '').trim().toUpperCase();
        if (!t) return '';
        if (t.charAt(0) === 'S') return 'S';
        if (t.charAt(0) === 'M') return 'M';
        if (t.charAt(0) === 'L') return 'L';
        return '';
    }

    function rollSimpleRange(textValue) {
        var t = normalizeDashText(textValue);
        var m;
        if (!t) return null;
        if (/^nil$/i.test(t)) return { label: t, rolled: 0, kind: 'nil' };
        m = t.match(/^(\d+)\s*-\s*(\d+)/);
        if (m) {
            var lo = parseInt(m[1], 10), hi = parseInt(m[2], 10);
            if (hi < lo) { var tmp = lo; lo = hi; hi = tmp; }
            return { label: lo + '-' + hi, rolled: randomInteger(hi - lo + 1) + lo - 1, kind: 'range' };
        }
        m = t.match(/^(\d+)/);
        if (m) return { label: m[1], rolled: parseInt(m[1], 10), kind: 'fixed' };
        return null;
    }

    function rollLairChance(textValue) {
        var t = normalizeDashText(textValue).trim();
        var m, pct, d100;
        if (!t || /^nil$/i.test(t)) return { label: '0%', rolled: 0, isInLair: false, kind: 'nil' };
        m = t.match(/(\d+)\s*%?/);
        if (!m) return null;
        pct = Math.max(0, Math.min(100, parseInt(m[1], 10)));
        d100 = randomInteger(100);
        return { label: pct + '%', rolled: d100, isInLair: d100 <= pct, kind: 'percent' };
    }

    function runHDSetOnSelection(msg, manualHD) {
        var i, sel, token, tokenName, charId;
        var hdRaw, bonusRaw, acValue, moveValue, parsedHD, rolled, moraleValue, updateObj;
        var errors = [];
        var successes = [];
        var manualText = trim(String(manualHD || ''));

        if (!msg.selected || !msg.selected.length) {
            whisperGM('<div style="padding:8px;border:1px solid #900;background:#220000;color:#fff;border-radius:6px;">No tokens selected.</div>');
            return;
        }

        for (i = 0; i < msg.selected.length; i++) {
            sel = msg.selected[i];
            if (sel._type !== 'graphic') continue;
            token = getObj('graphic', sel._id);
            if (!token) {
                errors.push('Selected object ' + sel._id + ' could not be read as a token.');
                continue;
            }

            tokenName = token.get('name') || ('Token ' + sel._id);
            charId = token.get('represents');
            if (!charId) {
                errors.push('<b>' + h(tokenName) + '</b>: no represented character.');
                continue;
            }

            hdRaw = getAttrByName(charId, ATTR_HD);
            bonusRaw = getAttrByName(charId, ATTR_HD_BONUS);
            acValue = chooseACValue(charId, token);
            moveValue = chooseMoveValue(charId, token);
            var noAppearingValue = getAttrByName(charId, 'no_appearing') || getAttrByName(charId, 'number_appearing');
            var lairValue = getAttrByName(charId, 'lair') || getAttrByName(charId, 'percent_in_lair');
            var rolledAppearing = rollSimpleRange(noAppearingValue);
            var rolledLair = rollLairChance(lairValue);

            if (manualText) {
                parsedHD = parseMonsterHD(manualText, 0);
            } else {
                parsedHD = parseMonsterHD(hdRaw, bonusRaw);
            }

            if (!parsedHD) {
                if (manualText) {
                    errors.push('<b>' + h(tokenName) + '</b>: bad manual HD <code>' + h(manualText) + '</code>');
                } else {
                    errors.push('<b>' + h(tokenName) + '</b>: bad HD. monsterhd=<code>' + h(hdRaw) + '</code>, monsterhd_bonus=<code>' + h(bonusRaw) + '</code>');
                }
                continue;
            }

            rolled = rollParsedHD(parsedHD);
            if (!rolled) {
                errors.push('<b>' + h(tokenName) + '</b>: roll failed.');
                continue;
            }

            moraleValue = calculateBaseMorale(parsedHD);
            setMoraleAttributes(charId, moraleValue);

            updateObj = {
                bar1_value: rolled.total,
                bar1_max: rolled.total
            };
            if (hasText(acValue)) updateObj.bar2_value = acValue;
            if (hasText(moveValue)) updateObj.bar3_value = moveValue;
            token.set(updateObj);

            successes.push('<b>' + h(tokenName) + '</b>: ' + h(parsedHD.label) + ' → HP <b>' + h(rolled.total) + '</b>' +
                (hasText(acValue) ? ', AC ' + h(acValue) : '') +
                (hasText(moveValue) ? ', MV ' + h(moveValue) : '') +
                (rolledAppearing ? ', No. Appearing ' + h(rolledAppearing.label) + ' → <b>' + h(rolledAppearing.rolled) + '</b>' : '') +
                (rolledLair ? ', In Lair ' + h(rolledLair.label) + ' → <b>' + h(rolledLair.rolled) + '</b> (' + h(rolledLair.isInLair ? 'Yes' : 'No') + ')' : '') +
                ', Morale ' + h(moraleValue) + '%');
        }

        if (successes.length) {
            whisperGM('<div style="padding:8px;border:1px solid #264b1f;background:#10240d;color:#fff;border-radius:6px;"><b>HD Updated</b><br><span style="color:#bbb;">HP • AC • movement • No. Appearing • In Lair • morale</span><br>' + successes.join('<br>') + '</div>');
        }

        if (errors.length) {
            whisperGM('<div style="padding:8px;border:1px solid #900;background:#220000;color:#fff;border-radius:6px;"><b>HD Errors</b><br>' + errors.join('<br>') + '</div>');
        }
    }

    
    on('chat:message', function(msg) {
        var content, args, parts, bookKey, letter, page, monster, matches, query;
        if (msg.type !== 'api' || !msg.content) return;
        content = trim(msg.content);
        if (content.toLowerCase() === HDSET_COMMAND || content.indexOf(HDSET_COMMAND + ' ') === 0) {
            var manualHDArg = '';
            if (content.indexOf(HDSET_COMMAND + ' ') === 0) manualHDArg = trim(content.substring(HDSET_COMMAND.length));
            runHDSetOnSelection(msg, manualHDArg);
            return;
        }
        if (content.indexOf(COMMAND) !== 0) return;
        args = trim(content.substring(COMMAND.length));
        
        if (!args || args === '--help') { showMainMenu(); return; }
        if (args.indexOf('--book ') === 0) { showBookMenu(trim(args.replace('--book', ''))); return; }
        if (args.indexOf('--findbook ') === 0) {
            parts = args.split(/\s+/);
            bookKey = parts[1];
            query = trim(args.replace(/^--findbook\s+\S+\s+/, ''));
            showMatches(query, findMatchesByBook(query, bookKey), bookKey);
            return;
        }
        if (args.indexOf('--find ') === 0) { query = trim(args.replace('--find', '')); showMatches(query, findMatchesByBook(query, null), null); return; }
        if (args.indexOf('--list ') === 0) {
            parts = args.split(/\s+/);
            bookKey = parts[1] || 'mm1';
            letter = (parts[2] || 'A').charAt(0).toUpperCase();
            page = parseInt(parts[3] || '1', 10);
            if (isNaN(page) || page < 1) page = 1;
            showLetter(bookKey, letter, page);
            return;
        }
        if (args === '--dinosaurs') { showDinosaurs(); return; }
        if (args === '--dragons') { showDragonsMenu(); return; }
        if (args === '--demons') { showDemonsMenu(); return; }
        if (args === '--devils') { showDevilsMenu(); return; }
        if (args === '--orcs') { showOrcsMenu(); return; }
        if (args.indexOf('--view ') === 0) {
            var backCmd = null;
            var viewPart = args;
            var backPos = args.indexOf(' --back ');
            if (backPos !== -1) {
                viewPart = args.substring(0, backPos);
                backCmd = decodeURIComponent(args.substring(backPos + 8));
            }
            monster = getMonsterById(trim(viewPart.replace('--view', '')));
            if (monster) renderMonsterCard(monster, backCmd);
            return;
        }
        if (args.indexOf('--attach ') === 0) { performMonsterAction(msg, trim(args.replace('--attach', '')), 'attach'); return; }
        if (args.indexOf('--create ') === 0) { performMonsterAction(msg, trim(args.replace('--create', '')), 'create'); return; }
        if (args.indexOf('--clone ') === 0) { performMonsterAction(msg, trim(args.replace('--clone', '')), 'clone'); return; }

        monster = findMonster(args);
        if (monster) renderMonsterCard(monster, null);
        else showMatches(args, findMatchesByBook(args, null), null);
    });
    log(SCRIPT + ' ready. Use !monster');
});
