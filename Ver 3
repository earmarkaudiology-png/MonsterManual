      "frequency": "Rare",
      "no_appearing": "5-20 (double in lair)",
      "armorclass": "3",
      "movement": "9\"",
      "monsterHD": "4",
      "percent_in_lair": "5%",
      "treasure_type": "See below",
      "no_of_attacks": "1",
      "damage_attack": "By weapon +3",
      "special_attacks": "See below",
      "special_defenses": "See below",
