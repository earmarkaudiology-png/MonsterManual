  "monster_manual_ii_quickwood_spy_tree": {
    "name": "QUICKWOOD, SPY TREE",
    "source": "Monster Manual II",
    "sheet": {
      "frequency": "Very rare",
      "no_appearing": "1 (90%), 2-4 (10%)",
      "armorclass": "5",
      "movement": "1\" (3\" for roots)",
      "monsterHD": "5-10 (5 hp/die)",
      "percent_in_lair": "100",
      "treasure_type": "See below",
      "no_of_attacks": "Special",
      "damage_attack": "Special",
      "special_attacks": "See below",
      "special_defenses": "Never surprised",
      "magic_resistance": "See below",
      "intelligence": "Very",
