      "special_attacks": "Spit; controls water in lair",
      "special_defenses": "Kiss; mesmerize men",
      "magic_resistance": "50%",
      "intelligence": "Very",
      "alignment": "Chaotic",
      "size": "M",
      "psionic_ability": "Nil",
      "attack_defense_modes": "Nil/nil",
      "level_xp_value": "IV/200 + 4/hp",
      "monsterhd": "4",
      "monsterhd_bonus": "",
