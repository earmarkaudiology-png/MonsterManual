      "special_attacks": "Possession",
      "special_defenses": "See below/none",
      "magic_resistance": "Standard",
      "intelligence": "Non-",
      "alignment": "Any",
      "size": "",
      "psionic_ability": "Nil",
      "attack_defense_modes": "Nil/nil",
      "level_xp_value": "IV/165 + 5/hp",
      "monsterhd": "5/victim's hp",
      "monsterhd_bonus": "",
