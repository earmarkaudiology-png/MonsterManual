  "monster_manual_ii_gibbering_mouther": {
    "name": "GIBBERING MOUTHER",
    "source": "Monster Manual II",
    "sheet": {
      "frequency": "Very rare",
      "no_appearing": "1",
      "armorclass": "1",
      "movement": "3\"/6\"",
      "monsterHD": "4+3",
