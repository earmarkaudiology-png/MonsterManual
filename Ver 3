      "size": "S",
      "psionic_ability": "Nil",
      "attack_defense_modes": "Nil/nil",
      "level_xp_value": "II/52 + 2/hp",
      "monsterhd": "2",
      "monsterhd_bonus": "",
      "morale_base": "",
