  "monster_manual_ii_farastu_tarry_demodand": {
    "name": "FARASTU, TARRY DEMODAND",
    "source": "Monster Manual II",
    "sheet": {
      "frequency": "Very rare",
      "no_appearing": "1 (2-12)",
      "armorclass": "-1",
      "movement": "15\"/30\"",
      "monsterHD": "11",
