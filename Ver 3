      "special_defenses": "Immune to fire",
      "magic_resistance": "Standard",
      "intelligence": "Semi-",
      "alignment": "Neutral evil",
      "size": "S",
      "psionic_ability": "Nil",
      "attack_defense_modes": "Nil/nil",
      "level_xp_value": "II/28 + 2/hp",
      "monsterhd": "2",
