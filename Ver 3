  "monster_manual_ii_fisher_cave": {
    "name": "FISHER, CAVE",
    "source": "Monster Manual II",
    "sheet": {
      "frequency": "Rare",
      "no_appearing": "1-4",
      "armorclass": "4",
      "movement": "1\"",
      "monsterHD": "3",
