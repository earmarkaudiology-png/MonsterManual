      "damage_attack": "1-12/1-12/2-24/5-50/1-10/1-10",
      "special_attacks": "\"Sharpness\" bite, terror",
      "special_defenses": "See below",
      "magic_resistance": "Standard",
      "intelligence": "Animal",
