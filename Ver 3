      "no_of_attacks": "3",
      "damage_attack": "As dagger",
      "special_attacks": "See below",
      "special_defenses": "See below",
      "magic_resistance": "Save as 19th-level clerics",
      "intelligence": "High to genius",
      "alignment": "Chaotic evil (neutral)",
      "size": "S (2' tall)",
      "psionic_ability": "Nil",
