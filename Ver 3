      "damage_attack": "By weapon type",
      "special_attacks": "See below",
      "special_defenses": "See below",
      "magic_resistance": "Variable (see below)",
      "intelligence": "Low to genius",
      "alignment": "Any (except good)",
      "size": "As original creature",
      "psionic_ability": "As original creature",
      "attack_defense_modes": "As original creature",
      "level_xp_value": "Variable",
      "monsterhd": "As original class and level",
