      "damage_attack": "1 hp",
      "special_attacks": "Webs, egg insertion",
      "special_defenses": "Nil",
      "magic_resistance": "Standard",
      "intelligence": "Semi-",
      "alignment": "Neutral",
      "size": "S",
      "psionic_ability": "Nil",
      "attack_defense_modes": "Nil/nil",
      "level_xp_value": "I/7 + 1/hp",
      "monsterhd": "1/2",
      "monsterhd_bonus": "",
