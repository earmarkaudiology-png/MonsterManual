      "no_of_attacks": "1",
      "damage_attack": "2-8 + paralysis",
      "special_attacks": "Gaze inspires fear",
      "special_defenses": "Nil",
      "magic_resistance": "120% to 1st-level spells",
      "intelligence": "Godlike",
