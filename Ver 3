  "monster_manual_ii_cat_lord": {
    "name": "CAT LORD",
    "source": "Monster Manual II",
    "sheet": {
      "frequency": "Very rare (unique)",
      "no_appearing": "1",
      "armorclass": "-9",
      "movement": "27\"/9\" (plus 30-foot spring)",
      "monsterHD": "81 hp (treat as 19 hit dice)",
      "percent_in_lair": ".01%",
      "treasure_type": "S, T, W, X",
      "no_of_attacks": "3 (see also below)",
