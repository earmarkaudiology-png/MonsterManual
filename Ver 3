      "treasure_type": "Q",
      "no_of_attacks": "6+",
      "damage_attack": "1 (x6) + 1 per round",
      "special_attacks": "Spit, babble, save vs. confusion",
      "special_defenses": "Control ground density for 5-foot radius",
      "magic_resistance": "Standard",
      "intelligence": "Semi-",
      "alignment": "Neutral",
      "size": "M",
      "psionic_ability": "Nil",
      "attack_defense_modes": "Nil/nil",
      "level_xp_value": "IV/210 + 5/hp",
      "monsterhd": "4",
